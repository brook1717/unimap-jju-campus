# ─── Django Core ───────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database (individual vars — used by settings.py) ──────────────────────
POSTGRES_DB=unimap_db
POSTGRES_USER=unimap_user
POSTGRES_PASSWORD=unimap_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# DATABASE_URL is provided here as a reference alternative (e.g. for dj-database-url).
# The project currently uses the individual POSTGRES_* variables above.
# DATABASE_URL=postgis://unimap_user:unimap_pass@db:5432/unimap_db

# ─── AWS S3 Storage (optional) ──────────────────────────────────────────────
# Set USE_S3=True to serve static and media files from S3.
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ─── GeoDjango Library Paths ────────────────────────────────────────────────
# Leave blank in Docker — ldconfig auto-detection handles this.
# Only set if running Django outside Docker on a host without standard lib paths.
GDAL_LIBRARY_PATH=
GEOS_LIBRARY_PATH=
