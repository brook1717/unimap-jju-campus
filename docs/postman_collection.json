{
  "info": {
    "name": "UniMap API",
    "_postman_id": "unimap-jju-campus-api",
    "description": "Complete API collection for UniMap — Smart Campus Navigation System for Jigjiga University. All endpoints return GeoJSON-compliant responses. Import and set {{base_url}} to http://localhost:8000.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string",
      "description": "Base URL of the UniMap backend API server."
    }
  ],
  "item": [
    {
      "name": "Locations",
      "description": "CampusLocation endpoints — buildings and points of interest on the JJU campus. All list responses are GeoJSON FeatureCollections.",
      "item": [
        {
          "name": "List All Locations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/locations/?format=json",
              "host": ["{{base_url}}"],
              "path": ["api", "locations", ""],
              "query": [
                { "key": "format", "value": "json" },
                { "key": "page", "value": "1", "disabled": true },
                { "key": "category", "value": "academic", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            },
            "description": "Returns a paginated GeoJSON FeatureCollection of all active campus locations (100 per page)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is valid JSON', function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test('Response is a GeoJSON FeatureCollection', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.type).to.eql('FeatureCollection');",
                  "    pm.expect(json.features).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('First feature has a Point geometry', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.features.length).to.be.above(0);",
                  "    pm.expect(json.features[0].geometry.type).to.eql('Point');",
                  "});",
                  "",
                  "pm.test('Features contain expected properties', function () {",
                  "    const props = pm.response.json().features[0].properties;",
                  "    pm.expect(props).to.have.property('name');",
                  "    pm.expect(props).to.have.property('slug');",
                  "    pm.expect(props).to.have.property('category');",
                  "    pm.expect(props).to.have.property('facilities');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Location by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/locations/1/?format=json",
              "host": ["{{base_url}}"],
              "path": ["api", "locations", "1", ""],
              "query": [{ "key": "format", "value": "json" }]
            },
            "description": "Returns a single GeoJSON Feature for the location with the given ID."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response type is Feature', function () {",
                  "    pm.expect(pm.response.json().type).to.eql('Feature');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Filter by Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/locations/?category=academic&format=json",
              "host": ["{{base_url}}"],
              "path": ["api", "locations", ""],
              "query": [
                { "key": "category", "value": "academic", "description": "One of: academic, classroom, office, lab, library, dormitory, cafeteria, gate, facility" },
                { "key": "format", "value": "json" }
              ]
            },
            "description": "Filter locations by category. Valid values: academic, classroom, office, lab, library, dormitory, cafeteria, gate, facility."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('All features match the requested category', function () {",
                  "    const features = pm.response.json().features;",
                  "    features.forEach(f => pm.expect(f.properties.category).to.eql('academic'));",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Search by Name or Description",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/locations/?search=main+entrance&format=json",
              "host": ["{{base_url}}"],
              "path": ["api", "locations", ""],
              "query": [
                { "key": "search", "value": "main entrance" },
                { "key": "format", "value": "json" }
              ]
            },
            "description": "Full-text search across the name and description fields."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Nearest Building",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/locations/nearest/?lat=9.357&lng=42.826&format=json",
              "host": ["{{base_url}}"],
              "path": ["api", "locations", "nearest", ""],
              "query": [
                { "key": "lat", "value": "9.357", "description": "Latitude (WGS 84)" },
                { "key": "lng", "value": "42.826", "description": "Longitude (WGS 84)" },
                { "key": "format", "value": "json" }
              ]
            },
            "description": "Returns the single nearest active building to the given coordinate, ranked by PostGIS geodesic distance."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is a GeoJSON Feature', function () {",
                  "    pm.expect(pm.response.json().type).to.eql('Feature');",
                  "});",
                  "pm.test('Geometry is a Point', function () {",
                  "    pm.expect(pm.response.json().geometry.type).to.eql('Point');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Paginate — Page 2",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/locations/?page=2&format=json",
              "host": ["{{base_url}}"],
              "path": ["api", "locations", ""],
              "query": [
                { "key": "page", "value": "2" },
                { "key": "format", "value": "json" }
              ]
            },
            "description": "Fetch the second page (locations 101–123) since PAGE_SIZE is 100."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Previous page link is present', function () {",
                  "    pm.expect(pm.response.json().previous).to.not.be.null;",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
