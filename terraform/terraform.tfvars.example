# ──────────────────────────────────────────────────────────────────────────────
# terraform.tfvars.example — Copy to terraform.tfvars and fill in your values
# ──────────────────────────────────────────────────────────────────────────────
# IMPORTANT: Never commit terraform.tfvars to version control.

aws_region    = "eu-west-1"
project_name  = "unimap"
instance_type = "t3.micro"
volume_size   = 30

# Your public IP for SSH access (find it: curl -s ifconfig.me)
# Must be in CIDR notation with /32
my_ip = "YOUR_PUBLIC_IP/32"

# Your SSH public key (paste the contents of ~/.ssh/id_ed25519.pub)
public_key = "ssh-ed25519 AAAA... your@email.com"
