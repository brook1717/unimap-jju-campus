# ─── Django ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── PostgreSQL / PostGIS ────────────────────────────────────────────────
POSTGRES_DB=unimap_db
POSTGRES_USER=unimap_user
POSTGRES_PASSWORD=unimap_pass
# DATABASE_URL is optional — if set it takes priority over individual vars.
# DATABASE_URL=postgis://unimap_user:unimap_pass@db:5432/unimap_db

# ─── CORS ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the React frontend.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Gunicorn ────────────────────────────────────────────────────────────
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# ─── Topology Data ───────────────────────────────────────────────────────
TOPOLOGY_GEOJSON_PATH=/data/topology_paths.geojson
